{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["vitest/globals", "@testing-library/jest-dom"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "ES2015",
    "jsx": "react-jsx"
  },
  "include": ["src/**/*.test.ts", "src/**/*.test.tsx", "src/__tests__/**/*"],
  "exclude": ["node_modules"]
}
